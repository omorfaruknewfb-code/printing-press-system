generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
}

enum OrderStatus {
  PENDING
  CONFIRMED
  READY_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum WithdrawalType {
  COMMISSION
  SALARY
  OTHER
}

model Counter {
  name  String @id
  value Int    @default(0)

  @@map("counters")
}

model Settings {
  id      String  @id @default("default")
  orgName String  @default("Al-Ihsan Printing Press")
  logoUrl String?

  @@map("settings")
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  passwordHash   String   @map("password_hash")
  role           Role
  isActive       Boolean  @default(true) @map("is_active")
  avatarUrl      String?  @map("avatar_url")
  commissionRate Decimal  @default(0) @map("commission_rate") @db.Decimal(5, 2)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  ordersTaken     Order[]                @relation("OrderTakenBy")
  ordersAssigned  Order[]                @relation("AssignedTo")
  expensesCreated Expense[]
  withdrawals     StaffWithdrawal[]
  statusChanges   OrderStatusHistory[]   @relation("StatusChangedBy")

  @@map("users")
}

model ItemMaster {
  id        String   @id @default(cuid())
  itemName  String   @unique @map("item_name")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("item_masters")
}

model ExpenseCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("expense_categories")
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  mobile      String   @unique
  address     String?
  totalOrders Int      @default(0) @map("total_orders")
  totalBill   Decimal  @default(0) @map("total_bill") @db.Decimal(12, 2)
  totalPaid   Decimal  @default(0) @map("total_paid") @db.Decimal(12, 2)
  totalDue    Decimal  @default(0) @map("total_due") @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  orders   Order[]
  payments CustomerPayment[]

  @@index([name])
  @@index([mobile])
  @@map("customers")
}

model Order {
  id             String      @id @default(cuid())
  orderId        String      @unique @map("order_id")
  date           DateTime
  customerId     String      @map("customer_id")
  totalBill      Decimal     @map("total_bill") @db.Decimal(12, 2)
  advance        Decimal     @default(0) @db.Decimal(12, 2)
  due            Decimal     @default(0) @db.Decimal(12, 2)
  totalCosting   Decimal     @default(0) @map("total_costing") @db.Decimal(12, 2)
  costingSet     Boolean     @default(false) @map("costing_set")
  discountAmount Decimal     @default(0) @map("discount_amount") @db.Decimal(12, 2)
  discountType   String?     @map("discount_type") // "PERCENTAGE" or "FIXED"
  adjustmentAmount Decimal   @default(0) @map("adjustment_amount") @db.Decimal(12, 2)
  deliveryDate   DateTime    @map("delivery_date")
  status         OrderStatus @default(PENDING)
  orderTakenById String      @map("order_taken_by_user_id")
  assignedToId   String?     @map("assigned_to_user_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  customer       Customer            @relation(fields: [customerId], references: [id])
  orderTakenBy   User                @relation("OrderTakenBy", fields: [orderTakenById], references: [id])
  assignedTo     User?               @relation("AssignedTo", fields: [assignedToId], references: [id])
  payments       CustomerPayment[]
  items          OrderItem[]
  statusHistory  OrderStatusHistory[]

  @@index([status])
  @@index([customerId])
  @@index([orderTakenById])
  @@index([deliveryDate])
  @@map("orders")
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String  @map("order_id")
  itemName   String  @map("item_name")
  description String?
  quantity   Int
  unitPrice  Decimal @default(0) @map("unit_price") @db.Decimal(12, 2)
  lineTotal  Decimal @default(0) @map("line_total") @db.Decimal(12, 2)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([itemName])
  @@map("order_items")
}

model CustomerPayment {
  id            String   @id @default(cuid())
  customerId    String   @map("customer_id")
  orderId       String?  @map("order_id")
  billAmount    Decimal  @map("bill_amount") @db.Decimal(12, 2)
  paidAmount    Decimal  @map("paid_amount") @db.Decimal(12, 2)
  dueAmount     Decimal  @map("due_amount") @db.Decimal(12, 2)
  remarks       String?
  paymentDate   DateTime @map("payment_date")
  collectedById String?  @map("collected_by_user_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id])
  order    Order?   @relation(fields: [orderId], references: [id])

  @@index([customerId])
  @@map("customer_payments")
}

model Expense {
  id          String   @id @default(cuid())
  date        DateTime
  category    String
  amount      Decimal  @db.Decimal(12, 2)
  description String?
  createdById String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy User @relation(fields: [createdById], references: [id])

  @@index([date])
  @@index([category])
  @@map("expenses")
}

model StaffWithdrawal {
  id              String         @id @default(cuid())
  staffId         String         @map("staff_id")
  type            WithdrawalType @default(COMMISSION)
  amount          Decimal        @db.Decimal(12, 2)
  date            DateTime
  remarks         String?
  relatedExpenseId String?       @map("related_expense_id")
  editedByAdmin   Boolean        @default(false) @map("edited_by_admin")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  staff User @relation(fields: [staffId], references: [id])

  @@index([staffId])
  @@index([date])
  @@map("staff_withdrawals")
}

model OrderStatusHistory {
  id          String      @id @default(cuid())
  orderId     String      @map("order_id")
  oldStatus   OrderStatus? @map("old_status")
  newStatus   OrderStatus @map("new_status")
  changedBy   String      @map("changed_by_user_id")
  remarks     String?
  changedAt   DateTime    @default(now()) @map("changed_at")

  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedByUser User      @relation("StatusChangedBy", fields: [changedBy], references: [id])

  @@index([orderId])
  @@index([changedBy])
  @@map("order_status_history")
}
